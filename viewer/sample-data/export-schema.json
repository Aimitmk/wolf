        "source": {
          "enum": [
            "speech",
            "vote"
          ],
          "title": "Source",
          "type": "string"
        },
        "event_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Event Id"
        },
        "seq": {
          "title": "Seq",
          "type": "integer"
